@page "/"
@using System.Timers
@using System.Collections.Generic
@implements IAsyncDisposable
@inject IJSRuntime JS

<PageTitle>Ramón & Artemis - Boda 2026</PageTitle>

<div class="page-wrapper">
    <!-- BACKGROUND ANIMATIONS -->
    <div class="background-animation">
        <div class="flower" style="--delay: 0s; --x: 10%;"></div>
        <div class="flower" style="--delay: 1s; --x: 20%;"></div>
        <div class="flower" style="--delay: 2s; --x: 30%;"></div>
        <div class="flower" style="--delay: 3s; --x: 40%;"></div>
        <div class="flower" style="--delay: 4s; --x: 50%;"></div>
        <div class="flower" style="--delay: 5s; --x: 60%;"></div>
        <div class="flower" style="--delay: 6s; --x: 70%;"></div>
        <div class="flower" style="--delay: 7s; --x: 80%;"></div>
        <div class="flower" style="--delay: 8s; --x: 90%;"></div>
    </div>

    <div class="container">
        <!-- HEADER -->
        <div class="header-section">
            <div class="header-content">
                <h1 class="names-title animate-fade-in-down">Ramón & Artemis</h1>
                <p class="subtitle animate-fade-in-down">Te invitamos a nuestro matrimonio</p>
                <div class="decorative-line"></div>
            </div>
        </div>

        <!-- MESSAGE SECTION -->
        <div class="message-section animate-fade-in">
            <p class="romantic-message">
                "Con la alegría en nuestros corazones, los invitamos a compartir el inicio de una nueva etapa. Que este día sea testigo de nuestro amor y de la felicidad que nos dan ustedes al acompañarnos."
            </p>
        </div>

        <!-- COUNTDOWN TIMER -->
        <div class="countdown-section">
            <h3>Faltan</h3>
            <div class="countdown">
                <div class="countdown-item">
                    <div class="countdown-number">@days</div>
                    <div class="countdown-label">Días</div>
                </div>
                <div class="countdown-item">
                    <div class="countdown-number">@hours</div>
                    <div class="countdown-label">Horas</div>
                </div>
                <div class="countdown-item">
                    <div class="countdown-number">@minutes</div>
                    <div class="countdown-label">Minutos</div>
                </div>
                <div class="countdown-item">
                    <div class="countdown-number">@seconds</div>
                    <div class="countdown-label">Segundos</div>
                </div>
            </div>
        </div>

        <!-- EVENT DETAILS -->
        <div class="details-section">
            <div class="detail-card">
                <div class="detail-icon">📅</div>
                <div class="detail-label">Fecha</div>
                <div class="detail-value">18 de Diciembre de 2026</div>
            </div>
            <div class="detail-card">
                <div class="detail-icon">⏰</div>
                <div class="detail-label">Hora</div>
                <div class="detail-value">6:00 PM</div>
            </div>
            <div class="detail-card">
                <div class="detail-icon">📍</div>
                <div class="detail-label">Ubicación</div>
                <div class="detail-value">Yabanal, Santiago R.D</div>
            </div>
        </div>

        <!-- DRESS CODE -->
        <div class="dress-code-section">
            <div class="dress-code-card">
                <div class="dress-code-icon">👔</div>
                <h3>Código de Vestimenta</h3>
                <p>Semi-formal</p>
                <p class="avoid-colors">Evita azul y blanco</p>
            </div>
        </div>

        <!-- ACTION BUTTONS -->
        <div class="buttons-section">
            <button class="btn btn-confirm" @onclick="MostrarFormulario">
                <span class="btn-icon">✓</span>
                Confirmar Asistencia
            </button>
            <button class="btn btn-location" @onclick="AbrirUbicacion">
                <span class="btn-icon">📍</span>
                Ver Ubicación
            </button>
        </div>

        <!-- CONFIRMATION FORM -->
        @if (mostrarFormulario)
        {
            <div class="modal-overlay" @onclick="CerrarFormulario">
                <div class="modal-content" @onclick:stopPropagation>
                    <button class="close-btn" @onclick="CerrarFormulario">×</button>
                    <h2>Confirmar Asistencia</h2>

                    <div class="form-group">
                        <label>Tu Nombre *</label>
                        <input type="text" @bind="nombre" placeholder="Ej: Juan García" />
                    </div>

                    <div class="form-group">
                        <label>Teléfono (Opcional)</label>
                        <input type="tel" @bind="telefono" placeholder="+1 (809) XXX-XXXX" />
                    </div>

                    <div class="form-group">
                        <label>¿Asistirás? *</label>
                        <div class="radio-group">
                            <label class="radio-label">
                                <input type="radio" value="si" @onchange="@((ChangeEventArgs e) => asistencia = e.Value?.ToString() ?? "")" />
                                Sí, asistiré
                            </label>
                            <label class="radio-label">
                                <input type="radio" value="no" @onchange="@((ChangeEventArgs e) => asistencia = e.Value?.ToString() ?? "")" />
                                No podré asistir
                            </label>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Comentarios (Opcional)</label>
                        <textarea @bind="comentarios" placeholder="Déjanos un mensaje..."></textarea>
                    </div>

                    <button class="btn btn-confirm" @onclick="EnviarConfirmacion">
                        Enviar Confirmación
                    </button>
                </div>
            </div>
        }

        <!-- QR CODES -->
        <div class="qr-section">
            <h3>Códigos QR</h3>
            <div class="qr-container">
                <div class="qr-card">
                    <img src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=Yabanal%2C%20Santiago%2C%20RD" alt="QR Ubicación" />
                    <p>Ubicación</p>
                </div>
                <div class="qr-card">
                    <img src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=https://bodainvitacion.app/confirmar" alt="QR Confirmación" />
                    <p>Confirmación</p>
                </div>
            </div>
        </div>

        <!-- MUSIC TOGGLE -->
        <button class="music-toggle @(musicaActiva ? "playing" : "")" @onclick="ToggleMusica" title="Música">
            @if (musicaActiva)
            {
                <span>🎶</span>
            }
            else
            {
                <span>🎵</span>
            }
        </button>
    </div>
</div>

@code {
    private int days = 0;
    private int hours = 0;
    private int minutes = 0;
    private int seconds = 0;
    private Timer? timer;
    private bool mostrarFormulario = false;
    private bool musicaActiva = false;

    // Form fields
    private string nombre = "";
    private string telefono = "";
    private string asistencia = "";
    private string comentarios = "";

    protected override async Task OnInitializedAsync()
    {
        ActualizarContador();
        timer = new Timer(1000);
        timer.Elapsed += async (sender, e) =>
        {
            await InvokeAsync(() =>
            {
                ActualizarContador();
                StateHasChanged();
            });
        };
        timer.Start();

        await JS.InvokeVoidAsync("inicializarAnimaciones");
    }

    private void ActualizarContador()
    {
        DateTime boda = new DateTime(2026, 12, 18, 18, 0, 0);
        TimeSpan tiempo = boda - DateTime.Now;

        days = tiempo.Days;
        hours = tiempo.Hours;
        minutes = tiempo.Minutes;
        seconds = tiempo.Seconds;
    }

    private void MostrarFormulario()
    {
        mostrarFormulario = true;
    }

    private void CerrarFormulario()
    {
        mostrarFormulario = false;
    }

    private async Task EnviarConfirmacion()
    {
        if (string.IsNullOrWhiteSpace(nombre) || string.IsNullOrWhiteSpace(asistencia))
        {
            await JS.InvokeVoidAsync("alert", "Por favor completa los campos requeridos");
            return;
        }

        // Aquí puedes enviar los datos a una API
        string mensaje = $"Nombre: {nombre}\nAsistencia: {asistencia}\nTeléfono: {telefono}\nComentarios: {comentarios}";
        await JS.InvokeVoidAsync("alert", "¡Confirmación recibida! Gracias por confirmar tu asistencia.");

        CerrarFormulario();
        LimpiarFormulario();
    }

    private void LimpiarFormulario()
    {
        nombre = "";
        telefono = "";
        asistencia = "";
        comentarios = "";
    }

    private async Task AbrirUbicacion()
    {
        await JS.InvokeVoidAsync("window.open", "https://www.google.com/maps/search/Yabanal,+Santiago,+RD", "_blank");
    }

    private async Task ToggleMusica()
    {
        musicaActiva = !musicaActiva;
        if (musicaActiva)
        {
            await JS.InvokeVoidAsync("reproducirMusica");
        }
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        if (timer is not null)
        {
            await timer.StopAsync();
            timer.Dispose();
        }
    }
}

<style>
    :root {
        --primary-color: #3b82f6;
        --primary-dark: #1e40af;
        --light-bg: #f0f4f8;
        --light-border: #e0e7ff;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    .page-wrapper {
        min-height: 100vh;
        background: linear-gradient(135deg, var(--light-bg) 0%, #e8f1f8 100%);
        position: relative;
        overflow: hidden;
    }

    /* BACKGROUND ANIMATIONS */
    .background-animation {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 0;
    }

    .flower {
        position: absolute;
        width: 20px;
        height: 20px;
        background: rgba(59, 130, 246, 0.1);
        border-radius: 50%;
        left: var(--x);
        animation: floatDown 15s infinite linear;
        animation-delay: var(--delay);
    }

    @keyframes floatDown {
        0% {
            top: -50px;
            opacity: 0;
        }
        10% {
            opacity: 1;
        }
        90% {
            opacity: 1;
        }
        100% {
            top: 100vh;
            opacity: 0;
            transform: translateX(100px);
        }
    }

    .container {
        position: relative;
        z-index: 1;
        max-width: 700px;
        margin: 0 auto;
        padding: 40px 20px;
    }

    /* ANIMATIONS */
    @keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    @keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fade-in-down {
        animation: fadeInDown 0.8s ease-out;
    }

    .animate-fade-in {
        animation: fadeIn 1s ease-out 0.3s both;
    }

    /* HEADER */
    .header-section {
        text-align: center;
        margin-bottom: 50px;
        background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
        color: white;
        padding: 60px 30px;
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(59, 130, 246, 0.2);
        position: relative;
        overflow: hidden;
    }

    .header-section::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -10%;
        width: 300px;
        height: 300px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 50%;
        animation: float 6s ease-in-out infinite;
    }

    @keyframes float {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(30px); }
    }

    .names-title {
        font-size: 3em;
        font-weight: 300;
        letter-spacing: 3px;
        margin-bottom: 10px;
        position: relative;
        z-index: 1;
    }

    .subtitle {
        font-size: 1.2em;
        opacity: 0.95;
        position: relative;
        z-index: 1;
    }

    .decorative-line {
        width: 80px;
        height: 3px;
        background: rgba(255, 255, 255, 0.5);
        margin: 20px auto 0;
        border-radius: 2px;
        animation: expandWidth 0.8s ease-out 0.5s both;
    }

    @keyframes expandWidth {
        from { width: 0; }
        to { width: 80px; }
    }

    /* MESSAGE */
    .message-section {
        text-align: center;
        margin-bottom: 50px;
        padding: 30px;
        background: white;
        border-radius: 15px;
        box-shadow: 0 5px 20px rgba(59, 130, 246, 0.1);
    }

    .romantic-message {
        font-size: 1.1em;
        color: var(--primary-dark);
        line-height: 1.8;
        font-style: italic;
    }

    /* COUNTDOWN */
    .countdown-section {
        text-align: center;
        margin-bottom: 50px;
        animation: slideUp 0.8s ease-out 0.4s both;
    }

    .countdown-section h3 {
        color: var(--primary-color);
        margin-bottom: 20px;
        font-size: 1.3em;
    }

    .countdown {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(80px, 1fr));
        gap: 15px;
    }

    .countdown-item {
        background: white;
        padding: 20px;
        border-radius: 10px;
        box-shadow: 0 5px 15px rgba(59, 130, 246, 0.1);
        transition: all 0.3s ease;
    }

    .countdown-item:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(59, 130, 246, 0.2);
    }

    .countdown-number {
        font-size: 2em;
        font-weight: bold;
        color: var(--primary-color);
    }

    .countdown-label {
        font-size: 0.85em;
        color: #666;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    /* DETAILS */
    .details-section {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 20px;
        margin-bottom: 50px;
        animation: slideUp 0.8s ease-out 0.5s both;
    }

    .detail-card {
        background: white;
        padding: 25px;
        border-radius: 15px;
        text-align: center;
        box-shadow: 0 5px 20px rgba(59, 130, 246, 0.1);
        transition: all 0.3s ease;
        border-left: 4px solid transparent;
    }

    .detail-card:hover {
        transform: translateY(-8px);
        border-left-color: var(--primary-color);
        box-shadow: 0 15px 35px rgba(59, 130, 246, 0.2);
    }

    .detail-icon {
        font-size: 2.5em;
        margin-bottom: 10px;
    }

    .detail-label {
        font-size: 0.85em;
        color: var(--primary-color);
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 600;
        margin-bottom: 8px;
    }

    .detail-value {
        font-size: 1em;
        color: var(--primary-dark);
        font-weight: 500;
    }

    /* DRESS CODE */
    .dress-code-section {
        margin-bottom: 50px;
        animation: slideUp 0.8s ease-out 0.6s both;
    }

    .dress-code-card {
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.05) 0%, rgba(30, 64, 175, 0.05) 100%);
        border: 2px solid var(--light-border);
        padding: 30px;
        border-radius: 15px;
        text-align: center;
        transition: all 0.3s ease;
    }

    .dress-code-card:hover {
        border-color: var(--primary-color);
        transform: translateY(-5px);
    }

    .dress-code-icon {
        font-size: 2.5em;
        margin-bottom: 15px;
    }

    .dress-code-card h3 {
        color: var(--primary-color);
        margin-bottom: 10px;
        font-size: 1.2em;
    }

    .dress-code-card p {
        color: var(--primary-dark);
        font-size: 1em;
        margin: 5px 0;
    }

    .avoid-colors {
        color: #f59e0b;
        font-weight: 600;
        margin-top: 10px !important;
    }

    /* BUTTONS */
    .buttons-section {
        display: flex;
        gap: 15px;
        margin-bottom: 50px;
        flex-wrap: wrap;
        animation: slideUp 0.8s ease-out 0.7s both;
    }

    .btn {
        flex: 1;
        min-width: 150px;
        padding: 15px 25px;
        border: none;
        border-radius: 10px;
        font-size: 1em;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

    .btn-confirm {
        background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
        color: white;
        box-shadow: 0 5px 15px rgba(59, 130, 246, 0.3);
    }

    .btn-confirm:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 30px rgba(59, 130, 246, 0.4);
    }

    .btn-location {
        background: white;
        color: var(--primary-color);
        border: 2px solid var(--primary-color);
    }

    .btn-location:hover {
        background: var(--light-bg);
        transform: translateY(-3px);
    }

    .btn-icon {
        font-size: 1.2em;
    }

    /* MODAL */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        animation: fadeIn 0.3s ease;
    }

    .modal-content {
        background: white;
        padding: 40px;
        border-radius: 20px;
        max-width: 500px;
        width: 90%;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        animation: slideUp 0.3s ease;
        position: relative;
    }

    .close-btn {
        position: absolute;
        top: 15px;
        right: 15px;
        background: none;
        border: none;
        font-size: 2em;
        cursor: pointer;
        color: #999;
    }

    .modal-content h2 {
        color: var(--primary-color);
        margin-bottom: 25px;
        text-align: center;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        color: var(--primary-dark);
        font-weight: 600;
        margin-bottom: 8px;
    }

    .form-group input[type="text"],
    .form-group input[type="tel"],
    .form-group textarea {
        width: 100%;
        padding: 12px;
        border: 2px solid var(--light-border);
        border-radius: 8px;
        font-family: inherit;
        transition: all 0.3s ease;
    }

    .form-group input[type="text"]:focus,
    .form-group input[type="tel"]:focus,
    .form-group textarea:focus {
        outline: none;
        border-color: var(--primary-color);
        box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
    }

    .form-group textarea {
        resize: vertical;
        min-height: 80px;
    }

    .radio-group {
        display: flex;
        gap: 20px;
    }

    .radio-label {
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        color: var(--primary-dark);
    }

    .radio-label input[type="radio"] {
        cursor: pointer;
        accent-color: var(--primary-color);
    }

    /* QR SECTION */
    .qr-section {
        text-align: center;
        margin-bottom: 50px;
        padding-top: 50px;
        border-top: 2px solid var(--light-border);
        animation: slideUp 0.8s ease-out 0.8s both;
    }

    .qr-section h3 {
        color: var(--primary-color);
        margin-bottom: 30px;
        font-size: 1.3em;
    }

    .qr-container {
        display: flex;
        gap: 30px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .qr-card {
        background: white;
        padding: 25px;
        border-radius: 15px;
        box-shadow: 0 5px 20px rgba(59, 130, 246, 0.1);
        transition: all 0.3s ease;
    }

    .qr-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 35px rgba(59, 130, 246, 0.2);
    }

    .qr-card img {
        width: 150px;
        height: 150px;
        margin-bottom: 15px;
        border-radius: 10px;
        border: 2px solid var(--light-border);
    }

    .qr-card p {
        color: var(--primary-color);
        font-weight: 600;
        font-size: 0.95em;
    }

    /* MUSIC TOGGLE */
    .music-toggle {
        position: fixed;
        bottom: 30px;
        right: 30px;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
        border: none;
        color: white;
        font-size: 1.8em;
        cursor: pointer;
        box-shadow: 0 5px 20px rgba(59, 130, 246, 0.3);
        transition: all 0.3s ease;
        z-index: 999;
    }

    .music-toggle:hover {
        transform: scale(1.1);
        box-shadow: 0 10px 30px rgba(59, 130, 246, 0.4);
    }

    .music-toggle.playing {
        animation: pulse 1.5s ease-in-out infinite;
    }

    @keyframes pulse {
        0%, 100% {
            box-shadow: 0 5px 20px rgba(59, 130, 246, 0.3);
        }
        50% {
            box-shadow: 0 5px 40px rgba(59, 130, 246, 0.6);
        }
    }

    /* RESPONSIVE */
    @media (max-width: 768px) {
        .container {
            padding: 20px 15px;
        }

        .names-title {
            font-size: 2em;
        }

        .countdown {
            grid-template-columns: repeat(2, 1fr);
        }

        .buttons-section {
            flex-direction: column;
        }

        .btn {
            min-width: 100%;
        }

        .music-toggle {
            bottom: 20px;
            right: 20px;
            width: 50px;
            height: 50px;
            font-size: 1.5em;
        }

        .modal-content {
            padding: 30px 20px;
        }
    }
</style>