@page "/"
@using System.Timers
@implements IAsyncDisposable
@inject IJSRuntime JS

<PageTitle>Ramón & Artemis - Boda 2026</PageTitle>

<div class="wedding-invitation">
    <!-- Confetti Canvas -->
    <canvas id="confetti-canvas" class="confetti-canvas"></canvas>
    
    <!-- Floating Flowers -->
    <div class="flowers-container" id="flowers-container"></div>

    <div class="content-wrapper">
        <!-- Hero Section -->
        <section class="hero-section">
            <h1 class="couple-names animate-fade-in">Ramón Domínguez</h1>
            <div class="ampersand animate-scale-in">♥</div>
            <h1 class="couple-names animate-fade-in-delay">Artemis González</h1>
            <p class="wedding-date animate-fade-in-delay-2">18 de Diciembre de 2026</p>
            <div class="divider-line animate-expand"></div>
        </section>

        <!-- Message Section -->
        <section class="message-section animate-slide-up">
            <p class="romantic-message">
                "Con la alegría en nuestros corazones, los invitamos a compartir el inicio de una nueva etapa. Que este día sea testigo de nuestro amor y de la felicidad que nos dan ustedes al acompañarnos."
            </p>
        </section>

        <!-- Countdown Timer -->
        <section class="countdown-section animate-slide-up-delay">
            <h2 class="section-title">Faltan</h2>
            <div class="countdown-container">
                <div class="countdown-box">
                    <span class="countdown-number">@days</span>
                    <span class="countdown-label">Días</span>
                </div>
                <div class="countdown-box">
                    <span class="countdown-number">@hours</span>
                    <span class="countdown-label">Horas</span>
                </div>
                <div class="countdown-box">
                    <span class="countdown-number">@minutes</span>
                    <span class="countdown-label">Minutos</span>
                </div>
                <div class="countdown-box">
                    <span class="countdown-number">@seconds</span>
                    <span class="countdown-label">Segundos</span>
                </div>
            </div>
        </section>

        <!-- Event Details -->
        <section class="details-section animate-slide-up-delay-2">
            <div class="detail-card">
                <div class="detail-icon">📅</div>
                <h3 class="detail-title">Fecha</h3>
                <p class="detail-text">18 de Diciembre<br>2026</p>
            </div>
            <div class="detail-card">
                <div class="detail-icon">⏰</div>
                <h3 class="detail-title">Hora</h3>
                <p class="detail-text">6:00 PM</p>
            </div>
            <div class="detail-card">
                <div class="detail-icon">📍</div>
                <h3 class="detail-title">Lugar</h3>
                <p class="detail-text">Yabanal<br>Santiago R.D</p>
            </div>
        </section>

        <!-- Dress Code -->
        <section class="dress-code-section animate-slide-up-delay-3">
            <div class="dress-code-card">
                <h3 class="dress-code-title">Código de Vestimenta</h3>
                <p class="dress-code-text">Semi-formal</p>
                <p class="dress-code-note">Por favor, evita los colores azul y blanco</p>
            </div>
        </section>

        <!-- QR Codes -->
        <section class="qr-section animate-slide-up-delay-4">
            <h2 class="section-title">Códigos QR</h2>
            <div class="qr-container">
                <div class="qr-card">
                    <img src="@qrLocationUrl" alt="QR Ubicación" />
                    <p class="qr-label">Ubicación en Maps</p>
                    <button class="qr-button" @onclick="AbrirUbicacion">Abrir en Google Maps</button>
                </div>
                <div class="qr-card">
                    <img src="@qrConfirmacionUrl" alt="QR Confirmación" />
                    <p class="qr-label">Confirmar Asistencia</p>
                    <button class="qr-button" @onclick="MostrarFormulario">Abrir Formulario</button>
                </div>
            </div>
        </section>

        <!-- Action Buttons -->
        <section class="actions-section animate-slide-up-delay-5">
            <button class="btn-primary" @onclick="MostrarFormulario">
                <span class="btn-icon">✓</span>
                Confirmar Asistencia
            </button>
            <button class="btn-secondary" @onclick="AbrirUbicacion">
                <span class="btn-icon">📍</span>
                Ver Ubicación
            </button>
        </section>
    </div>

    <!-- Confirmation Modal -->
    @if (mostrarFormulario)
    {
        <div class="modal-overlay" @onclick="CerrarFormulario">
            <div class="modal-content" @onclick:stopPropagation>
                <button class="modal-close" @onclick="CerrarFormulario" aria-label="Cerrar">×</button>
                <h2 class="modal-title">Confirmar Asistencia</h2>
                
                <form @onsubmit="ValidarYEnviar" @onsubmit:preventDefault="true">
                    <div class="form-group">
                        <label for="nombre" class="form-label">Tu Nombre *</label>
                        <input type="text"
                               id="nombre"
                               class="form-input @(errorNombre ? "error" : "")"
                               @bind="confirmacionModel.Nombre"
                               @bind:event="oninput"
                               @* @oninput="@(() => errorNombre = false)" *@
                               placeholder="Ej: Juan García" />
                        @if (errorNombre)
                        {
                            <span class="validation-message">El nombre es requerido</span>
                        }
                    </div>

                    <div class="form-group">
                        <label for="telefono" class="form-label">Teléfono (Opcional)</label>
                        <input type="tel" id="telefono" class="form-input" @bind="confirmacionModel.Telefono" placeholder="+1 (809) XXX-XXXX" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">¿Asistirás? *</label>
                        <div class="radio-group">
                            <label class="radio-option">
                                <input type="radio" name="asistencia" value="Si" checked="@(confirmacionModel.Asistencia == "Si")" @onchange="@((ChangeEventArgs e) => { confirmacionModel.Asistencia = e.Value?.ToString(); errorAsistencia = false; })" />
                                <span>Sí, asistiré</span>
                            </label>
                            <label class="radio-option">
                                <input type="radio" name="asistencia" value="No" checked="@(confirmacionModel.Asistencia == "No")" @onchange="@((ChangeEventArgs e) => { confirmacionModel.Asistencia = e.Value?.ToString(); errorAsistencia = false; })" />
                                <span>No podré asistir</span>
                            </label>
                        </div>
                        @if (errorAsistencia)
                        {
                            <span class="validation-message">Por favor indica si asistirás</span>
                        }
                    </div>

                    <div class="form-group">
                        <label for="comentarios" class="form-label">Comentarios (Opcional)</label>
                        <textarea id="comentarios" class="form-textarea" @bind="confirmacionModel.Comentarios" placeholder="Déjanos un mensaje..." rows="4"></textarea>
                    </div>

                    <button type="submit" class="btn-primary btn-submit">
                        Enviar Confirmación
                    </button>
                </form>
            </div>
        </div>
    }

    <!-- Music Toggle -->
    <button class="music-toggle @(musicaActiva ? "playing" : "")" @onclick="ToggleMusica" title="@(musicaActiva ? "Detener música" : "Reproducir música")">
        @if (musicaActiva)
        {
            <span>🎵</span>
        }
        else
        {
            <span>🔇</span>
        }
    </button>

    <!-- Audio Element -->
    <audio id="wedding-music" loop preload="auto" style="display: none;">
        <source src="/audio/wedding-music.mp3" type="audio/mpeg">
        Tu navegador no soporta audio HTML5.
    </audio>
</div>

@code {
    private System.Timers.Timer? countdownTimer;
    private bool mostrarFormulario = false;
    private bool musicaActiva = false;
    private int days = 0;
    private int hours = 0;
    private int minutes = 0;
    private int seconds = 0;
    private bool errorNombre = false;
    private bool errorAsistencia = false;

    private ConfirmacionModel confirmacionModel = new();

    private readonly DateTime fechaBoda = new(2026, 12, 18, 18, 0, 0);
    private readonly string locationUrl = "https://www.google.com/maps/search/Yabanal,+Santiago,+Dominican+Republic";
    private readonly string uberUrl = "https://m.uber.com/ul/?action=setPickup&pickup=my_location&dropoff[formatted_address]=Yabanal,%20Santiago,%20Dominican%20Republic";
    private string qrLocationUrl => $"https://api.qrserver.com/v1/create-qr-code/?size=200x200&data={Uri.EscapeDataString(locationUrl)}";
    private string qrConfirmacionUrl => $"https://api.qrserver.com/v1/create-qr-code/?size=200x200&data={Uri.EscapeDataString("CONFIRMAR ASISTENCIA - Ramón & Artemis - 18 Dic 2026 - Escanea y visita la página para confirmar")}";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("window.initWeddingAnimations");
            ActualizarContador();
            
            countdownTimer = new System.Timers.Timer(1000);
            countdownTimer.Elapsed += async (sender, e) =>
            {
                await InvokeAsync(() =>
                {
                    ActualizarContador();
                    StateHasChanged();
                });
            };
            countdownTimer.AutoReset = true;
            countdownTimer.Start();
        }
    }

    private void ActualizarContador()
    {
        var tiempoRestante = fechaBoda - DateTime.Now;
        
        if (tiempoRestante.TotalSeconds > 0)
        {
            days = tiempoRestante.Days;
            hours = tiempoRestante.Hours;
            minutes = tiempoRestante.Minutes;
            seconds = tiempoRestante.Seconds;
        }
        else
        {
            days = 0;
            hours = 0;
            minutes = 0;
            seconds = 0;
        }
    }

    private void MostrarFormulario()
    {
        mostrarFormulario = true;
        StateHasChanged();
    }

    private void CerrarFormulario()
    {
        mostrarFormulario = false;
        confirmacionModel = new ConfirmacionModel();
        errorNombre = false;
        errorAsistencia = false;
    }

    private async Task ValidarYEnviar()
    {
        errorNombre = string.IsNullOrWhiteSpace(confirmacionModel.Nombre);
        errorAsistencia = string.IsNullOrWhiteSpace(confirmacionModel.Asistencia);

        if (errorNombre || errorAsistencia)
        {
            StateHasChanged();
            return;
        }

        await EnviarConfirmacion();
    }

    private async Task EnviarConfirmacion()
    {
        // Aquí puedes agregar la lógica para enviar a una API
        // Por ahora, solo mostramos un mensaje
        await JS.InvokeVoidAsync("alert", 
            $"¡Gracias {confirmacionModel.Nombre}!\n\n" +
            $"Tu confirmación ha sido recibida.\n" +
            $"Asistencia: {confirmacionModel.Asistencia}\n\n" +
            "Nos vemos el 18 de Diciembre de 2026!"
        );

        CerrarFormulario();
    }

    private async Task AbrirUbicacion()
    {
        await JS.InvokeVoidAsync("eval", $"window.open('{locationUrl}', '_blank')");
    }

    private async Task ToggleMusica()
    {
        musicaActiva = !musicaActiva;
        if (musicaActiva)
        {
            await JS.InvokeVoidAsync("window.playWeddingMusic");
        }
        else
        {
            await JS.InvokeVoidAsync("window.pauseWeddingMusic");
        }
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        if (countdownTimer is not null)
        {
            countdownTimer.Stop();
            countdownTimer.Dispose();
            countdownTimer = null;
        }
    }

    public class ConfirmacionModel
    {
        public string Nombre { get; set; } = string.Empty;
        public string? Telefono { get; set; }
        public string? Asistencia { get; set; }
        public string? Comentarios { get; set; }
    }
}
